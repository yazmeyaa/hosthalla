package modal

css modal_dialog() {
	width: min(520px, calc(100vw - 24px));
	padding: 0;
	border: 1px solid var(--border);
	border-radius: var(--radius-xl);
	background: var(--card);
	color: var(--text);
}

css modal_content() {
	padding: var(--space-14);
	display: flex;
	flex-direction: column;
	gap: 12px;
}

css modal_title() {
	margin: 0;
	color: var(--text);
	font-size: 1.8rem;
	line-height: 1.2;
}

css modal_actions() {
	display: flex;
	justify-content: flex-end;
	gap: 8px;
}
