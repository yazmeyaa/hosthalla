package input

css input_styles() {
	padding: 0.5rem;
	background-color: var(--card);
	border: 1px solid var(--border);
	border-radius: var(--radius-sm);
	font-size: 1rem;
	font-family: inherit;
	line-height: 1.5;
	color: var(--text);
	width: 100%;
	box-sizing: border-box;
	outline: none;
	transition: border-color 160ms ease, box-shadow 180ms ease, background-color 160ms ease;
}
