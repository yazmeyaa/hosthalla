package hosts_page

css hosts_page_header() {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 12px;
	margin-bottom: 14px;
	padding-inline: 12px;
}

css hosts_page_title() {
	margin: 0;
}

css hosts_page_actions() {
	display: flex;
	align-items: center;
	gap: 8px;
}

css hosts_page_ping_all_form() {
	margin: 0;
}

css hosts_page_ping_all_status_slot() {
	min-height: 1.2rem;
	padding-inline: 12px;
	margin-bottom: 8px;
}
